{
  "name": "automaticpallet-payload",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NEXT_PUBLIC_IS_BUILDING=true NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "deploy": "pnpm run deploy:database && pnpm run deploy:app",
    "deploy:app": "opennextjs-cloudflare build --env=$CLOUDFLARE_ENV && opennextjs-cloudflare deploy --env=$CLOUDFLARE_ENV",
    "deploy:database": "cross-env NODE_ENV=production PAYLOAD_SECRET=ignore payload migrate && wrangler d1 execute D1 --command 'PRAGMA optimize' --env=$CLOUDFLARE_ENV --remote",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 8787",
    "dev:e2e": "rm -rf .wrangler/state/v3/d1 && cross-env NODE_OPTIONS=--no-deprecation payload migrate && pnpm dev",
    "start:e2e": "rm -rf .wrangler/state/v3/d1 && cross-env NODE_OPTIONS=--no-deprecation payload migrate && pnpm build && pnpm start",
    "devsafe": "rm -rf .next && rm -rf .open-next && rm -rf .wrangler/state/v3/d1 && cross-env NODE_OPTIONS=--no-deprecation payload migrate && cross-env NODE_OPTIONS=--no-deprecation next dev -p 8787",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "pnpm run generate:types:cloudflare && pnpm run generate:types:payload",
    "generate:types:cloudflare": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "generate:types:payload": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "pnpm install --ignore-workspace",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation next lint --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "jobs:trigger": "curl http://localhost:8787/cdn-cgi/handler/scheduled",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview --env=$CLOUDFLARE_ENV",
    "preview:e2e": "rm -rf .open-next && rm -rf .wrangler/state/v3/d1 && cross-env NODE_OPTIONS=--no-deprecation payload migrate && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" pnpm exec playwright test",
    "test:e2e:dev": "cross-env PLAYWRIGHT_COMMAND=\"pnpm run dev:e2e\" pnpm run test:e2e",
    "test:int": "mkdir -p .open-next/assets && cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@alexasomba/paystack-browser": "^1.2.1",
    "@alexasomba/paystack-node": "^1.2.1",
    "@onesignal/node-onesignal": "5.4.0-beta1",
    "@opennextjs/cloudflare": "^1.17.1",
    "@payloadcms/admin-bar": "~3.79.0",
    "@payloadcms/db-d1-sqlite": "~3.79.0",
    "@payloadcms/email-nodemailer": "~3.79.0",
    "@payloadcms/live-preview-react": "~3.79.0",
    "@payloadcms/next": "~3.79.0",
    "@payloadcms/plugin-ecommerce": "~3.79.0",
    "@payloadcms/plugin-form-builder": "~3.79.0",
    "@payloadcms/plugin-import-export": "~3.79.0",
    "@payloadcms/plugin-nested-docs": "~3.79.0",
    "@payloadcms/plugin-redirects": "~3.79.0",
    "@payloadcms/plugin-search": "~3.79.0",
    "@payloadcms/plugin-seo": "~3.79.0",
    "@payloadcms/richtext-lexical": "~3.79.0",
    "@payloadcms/storage-r2": "~3.79.0",
    "@payloadcms/translations": "~3.79.0",
    "@payloadcms/ui": "~3.79.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "dotenv": "16.6.1",
    "embla-carousel-auto-scroll": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "geist": "^1.7.0",
    "graphql": "^16.13.1",
    "jsonwebtoken": "~9.0.3",
    "lucide-react": "^0.577.0",
    "next": "~15.4.11",
    "next-sitemap": "^4.2.3",
    "next-themes": "0.4.6",
    "payload": "~3.79.0",
    "prism-react-renderer": "^2.4.1",
    "qs-esm": "^7.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "7.71.1",
    "sharp": "~0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.21",
    "@eslint/eslintrc": "^3.3.5",
    "@next/eslint-plugin-next": "~15.4.11",
    "@playwright/test": "~1.58.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/postcss": "~4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "~16.3.2",
    "@types/escape-html": "^1.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/git-hooks": "^1.0.0",
    "@vitejs/plugin-react": "~5.1.4",
    "autoprefixer": "^10.4.27",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "~15.4.11",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "6.1.0",
    "jsdom": "28.0.0",
    "lefthook": "^2.1.4",
    "lint-staged": "^16.3.3",
    "playwright": "~1.58.2",
    "playwright-core": "1.58.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "tsx": "4.21.0",
    "typescript": "~5.9.3",
    "vite-tsconfig-paths": "~6.1.1",
    "vitest": "~3.2.4",
    "wrangler": "~4.71.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,scss}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "cloudflare": {
    "bindings": {
      "PAYLOAD_SECRET": {
        "description": "Generate a random string using `openssl rand -hex 32`"
      }
    }
  }
}
