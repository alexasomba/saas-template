{
  "name": "my-better-t-app",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@cloudflare/workers-types": "^4.20251213.0",
      "hono": "^4.8.2",
      "@orpc/server": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/zod": "^1.12.2",
      "better-auth": "1.5.2",
      "ai": "^6.0.3",
      "alchemy": "^0.87.0",
      "wrangler": "^4.54.0",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.1.18",
      "@libsql/client": "0.15.15",
      "libsql": "0.5.22",
      "@orpc/tanstack-query": "^1.13.6",
      "@orpc/client": "^1.12.2",
      "@tanstack/react-form": "^1.28.0",
      "@ai-sdk/react": "^3.0.3",
      "@types/react-dom": "^19.2.3",
      "@better-auth/expo": "1.5.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:desktop": "turbo -F desktop dev:hmr",
    "build:desktop": "turbo -F desktop build:stable",
    "build:desktop:canary": "turbo -F desktop build:canary",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @my-better-t-app/db db:push",
    "db:generate": "turbo -F @my-better-t-app/db db:generate",
    "deploy": "turbo -F @my-better-t-app/infra deploy",
    "destroy": "turbo -F @my-better-t-app/infra destroy",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@my-better-t-app/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@my-better-t-app/config": "workspace:*",
    "@types/node": "^22.13.14",
    "lefthook": "^2.0.13",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.10"
}
